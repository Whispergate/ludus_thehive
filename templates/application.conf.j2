# TheHive configuration - managed by Ansible
# Do not edit manually

## Secret key
{% if ludus_thehive_secret %}
play.http.secret.key = "{{ ludus_thehive_secret }}"
{% endif %}

## Database configuration - Cassandra
db.janusgraph {
  storage {
    backend = cql
    hostname = ["{{ ludus_thehive_cassandra_listen_address }}"]
    cql {
      cluster-name = {{ ludus_thehive_cassandra_cluster_name }}
      keyspace = {{ ludus_thehive_cassandra_keyspace }}
      local-datacenter = datacenter1
      read-consistency-level = ONE
      write-consistency-level = ONE
    }
    username = "{{ ludus_thehive_cassandra_thehive_user }}"
    password = "{{ ludus_thehive_cassandra_thehive_password }}"
  }

  ## Index configuration - Elasticsearch
  index.search {
    backend = elasticsearch
    hostname = ["{{ ludus_thehive_elasticsearch_host }}"]
    index-name = {{ ludus_thehive_elasticsearch_index }}
    elasticsearch {
      http {
        port = {{ ludus_thehive_elasticsearch_port }}
      }
    }
  }
}

## File storage
storage {
{% if ludus_thehive_storage_type == "local" %}
  provider = localfs
  localfs.location = {{ ludus_thehive_storage_local_path }}
{% elif ludus_thehive_storage_type == "s3" %}
  provider = s3
  s3 {
    endpoint = "{{ ludus_thehive_storage_s3_endpoint }}"
    bucket = "{{ ludus_thehive_storage_s3_bucket }}"
    accessKey = "{{ ludus_thehive_storage_s3_access_key }}"
    secretKey = "{{ ludus_thehive_storage_s3_secret_key }}"
    region = "us-east-1"
  }
{% endif %}
}

## Cortex configuration
{% if ludus_thehive_cortex_enabled %}
play.modules.enabled += org.thp.thehive.connector.cortex.CortexModule
cortex {
  servers = [
    {
      name = Cortex
      url = "{{ ludus_thehive_cortex_url }}"
      auth {
        type = "bearer"
        key = "{{ ludus_thehive_cortex_api_key }}"
      }
    }
  ]
}
{% endif %}

## MISP configuration
{% if ludus_thehive_misp_enabled and ludus_thehive_misp_servers | length > 0 %}
play.modules.enabled += org.thp.thehive.connector.misp.MispModule
misp {
  interval = 1 hour
  servers = [
{% for server in ludus_thehive_misp_servers %}
    {
      name = "{{ server.name }}"
      url = "{{ server.url }}"
      auth {
        type = key
        key = "{{ server.auth_key }}"
      }
{% if server.organisation is defined %}
      organisation = "{{ server.organisation }}"
{% endif %}
{% if server.max_age_days is defined %}
      max-age = {{ server.max_age_days }} days
{% endif %}
{% if server.purpose is defined %}
      purpose = {{ server.purpose }}
{% endif %}
{% if server.case_template is defined and server.case_template %}
      caseTemplate = "{{ server.case_template }}"
{% endif %}
{% if server.exclude_organisations is defined and server.exclude_organisations | length > 0 %}
      exclusion.organisation = [{{ server.exclude_organisations | map('regex_replace', '^(.*)$', '"\\1"') | join(', ') }}]
{% endif %}
{% if server.exclude_tags is defined and server.exclude_tags | length > 0 %}
      exclusion.tags = [{{ server.exclude_tags | map('regex_replace', '^(.*)$', '"\\1"') | join(', ') }}]
{% endif %}
{% if server.include_tags is defined and server.include_tags | length > 0 %}
      whitelist.tags = [{{ server.include_tags | map('regex_replace', '^(.*)$', '"\\1"') | join(', ') }}]
{% endif %}
{% if server.ws_ssl_verify is defined %}
      wsConfig.ssl.loose.acceptAnyCertificate = {{ 'true' if not server.ws_ssl_verify else 'false' }}
{% endif %}
    }
{% if not loop.last %},{% endif %}
{% endfor %}
  ]
}
{% endif %}

## Application configuration
application.baseUrl = "http://{{ ansible_default_ipv4.address }}:{{ ludus_thehive_port }}"
play.http.parser.maxDiskBuffer = 1G
