# Resource override for smaller Ludus VMs - managed by Ansible
# Shrinks heap and container memory limits so the stack fits on an 8 GB VM.
# Remove ludus_thehive_small_resources from your role_vars to disable.

services:
  cassandra:
    environment:
      - CASSANDRA_CLUSTER_NAME=TheHive
      - CASSANDRA_AUTHENTICATOR=PasswordAuthenticator
      - CASSANDRA_NUM_TOKENS=4
      - HEAP_NEWSIZE={{ ludus_thehive_cassandra_heap_newsize }}
      - MAX_HEAP_SIZE={{ ludus_thehive_cassandra_heap_size }}
    deploy:
      resources:
        limits:
          memory: {{ ludus_thehive_cassandra_memory_limit }}
    memswap_limit: {{ ludus_thehive_cassandra_memory_limit }}

  elasticsearch:
    environment:
      - http.host=0.0.0.0
      - discovery.type=single-node
      - cluster.name=hive
      - thread_pool.search.queue_size=100000
      - thread_pool.write.queue_size=100000
      - bootstrap.memory_lock=false
      - xpack.security.enabled=true
      - ELASTIC_PASSWORD=${elasticsearch_password}
      - ES_JAVA_OPTS=-Xms{{ ludus_thehive_elasticsearch_heap }} -Xmx{{ ludus_thehive_elasticsearch_heap }}
    deploy:
      resources:
        limits:
          memory: {{ ludus_thehive_elasticsearch_memory_limit }}
    memswap_limit: {{ ludus_thehive_elasticsearch_memory_limit }}

  thehive:
    environment:
      - |
        JAVA_OPTS=
          -Xms{{ ludus_thehive_java_heap }}
          -Xmx{{ ludus_thehive_java_heap }}
          -XX:MaxMetaspaceSize=256m
          -XX:ReservedCodeCacheSize=256m
    healthcheck:
      test: ["CMD-SHELL", "curl -s -f http://thehive:9000/api/v1/status/public || exit 1"]
      start_period: 300s
      interval: 15s
      timeout: 10s
      retries: 10
    deploy:
      resources:
        limits:
          memory: {{ ludus_thehive_memory_limit }}
    memswap_limit: {{ ludus_thehive_memory_limit }}
{% if not ludus_thehive_enable_nginx %}

  nginx:
    profiles:
      - disabled
{% endif %}
