---
# Managed by Ansible
# Resource overrides for Ludus TheHive stack.
# Shrinks heap and container memory limits so the stack fits on the VM.
# Remove ludus_thehive_small_resources from your role_vars to disable.

services:
  cassandra:
    environment:
      - CASSANDRA_CLUSTER_NAME=TheHive
      - CASSANDRA_AUTHENTICATOR=PasswordAuthenticator
      - CASSANDRA_NUM_TOKENS=4
      - HEAP_NEWSIZE={{ ludus_thehive_cassandra_heap_newsize }}
      - MAX_HEAP_SIZE={{ ludus_thehive_cassandra_heap_size }}
    mem_limit: {{ ludus_thehive_cassandra_memory_limit }}
    memswap_limit: {{ ludus_thehive_cassandra_memory_swap_limit | default(ludus_thehive_cassandra_memory_limit) }}

  elasticsearch:
    environment:
      - http.host=0.0.0.0
      - discovery.type=single-node
      - cluster.name=hive
      - thread_pool.search.queue_size=100000
      - thread_pool.write.queue_size=100000
      - bootstrap.memory_lock=false
      - xpack.security.enabled=true
      - ELASTIC_PASSWORD=${elasticsearch_password}
      - ES_JAVA_OPTS=-Xms{{ ludus_thehive_elasticsearch_heap }} -Xmx{{ ludus_thehive_elasticsearch_heap }}
    mem_limit: {{ ludus_thehive_elasticsearch_memory_limit }}
    memswap_limit: {{ ludus_thehive_elasticsearch_memory_swap_limit | default(ludus_thehive_elasticsearch_memory_limit) }}

  thehive:
    environment:
      - |
        JAVA_OPTS=
          -Xms{{ ludus_thehive_java_xms }}
          -Xmx{{ ludus_thehive_java_xmx }}
          -XX:MaxMetaspaceSize={{ ludus_thehive_java_metaspace }}
          -XX:ReservedCodeCacheSize={{ ludus_thehive_java_code_cache }}
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:9000/api/v1/status/public"]
      start_period: 300s
      interval: 15s
      timeout: 10s
      retries: 20
    mem_limit: {{ ludus_thehive_memory_limit }}
    memswap_limit: {{ ludus_thehive_memory_swap_limit | default(ludus_thehive_memory_limit) }}

{% if not ludus_thehive_enable_nginx %}
  nginx:
    profiles:
      - disabled
{% endif %}
